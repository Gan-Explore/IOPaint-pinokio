{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "iopaint start --model=runwayml/stable-diffusion-inpainting --device=cpu --port=8080",
        "path": "app",
        "venv": "env",
        "env": {
          "PYTHONHTTPSVERIFY": "0",
          "HF_HUB_DISABLE_SSL_VERIFY": "1"
        },
        "wait": "/http:\\/\\/\\S+/"
      }
    },
    {
      "method": "browser.open",
      "params": {
        "url": "http://localhost:8080"
      }
    }
  ]
}
